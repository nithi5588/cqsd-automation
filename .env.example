# === App ===
NODE_ENV=development
PORT=3000
APP_BASE_URL=http://localhost:3000
JWT_SECRET=change-me-to-a-long-random-string
JWT_ISSUER=cqsd-marketing-automation
JWT_AUDIENCE=cqsd-dashboard
# 32-byte base64 key for encrypting OAuth tokens at rest.
# Generate with: openssl rand -base64 32   (or in PowerShell:
#   [Convert]::ToBase64String((1..32 | ForEach-Object { Get-Random -Maximum 256 })) )
ENCRYPTION_KEY=base64-32-byte-key-generate-with-opensslrand

# === Database ===
# docker-compose maps Postgres to host port 5433 (not 5432) to avoid colliding with a
# locally-installed Postgres service. Adjust if your local Postgres is on a different port.
DATABASE_URL=postgresql://cqsd:cqsd@localhost:5433/cqsd

# === Redis (BullMQ job queue) ===
REDIS_URL=redis://localhost:6379

# === Dashboard (Next.js, runs on port 3001; the API stays on 3000) ===
NEXT_PUBLIC_API_URL=http://localhost:3000

# === Seed ===
# Set to "false" to seed only the admin user (no demo companies/campaigns/webinars).
SEED_SAMPLE_DATA=true

# === Constant Contact (API v3) ===
# From https://developer.constantcontact.com -> My Applications.
# The "API key" shown there IS the OAuth client id.
# CC_CLIENT_SECRET is OPTIONAL: apps created without a secret use PKCE automatically —
# leave it empty in that case.
CC_CLIENT_ID=your-api-key
CC_CLIENT_SECRET=
CC_REDIRECT_URI=http://localhost:3000/oauth/constant-contact/callback
CC_SCOPES=contact_data campaign_data account_read offline_access

# === Microsoft Graph / Teams ===
# From Azure Portal -> Microsoft Entra ID -> App registrations (see docs/TEAMS_SETUP.md).
MS_TENANT_ID=
MS_CLIENT_ID=
MS_CLIENT_SECRET=
# The mailbox that organizes webinars (needs M365 E3/E5 or Teams Premium).
MS_ORGANIZER_UPN=webinar@cqsddigital.com
MS_REDIRECT_URI=http://localhost:3000/oauth/microsoft/callback
MS_DELEGATED_SCOPES=offline_access VirtualEvent.ReadWrite
# "true" (default) = Teams emails registrants their join link + reminders (recommended).
# Set to "false" to silence Teams and send all comms from your own domain instead.
MS_TEAMS_ATTENDEE_EMAILS=true
